# ==========================================
# SimuMath - Git Ignore Configuration
# ==========================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.venv/
.env/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
.eggs/

# --- Node / Next.js ---
node_modules/
/frontend/.next/
/frontend/out/
.npm
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Environment Variables (Security) ---
# Se ignoran los archivos .env para evitar subir credenciales o configuraciones locales al repositorio
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
# Exceptuar archivos de ejemplo
!.env.example

# --- IDEs / Editors ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# --- OS System Files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
